# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL + keys from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Anthropic (grant intelligence engine) ───────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Grants.gov / Simpler.grants.gov ingest ──────────────────────────────────
# API key from: https://simpler.grants.gov/developer
SIMPLER_GOV_API_KEY=
# Shared secret for the scheduled ingest route. Vercel Cron sends it as a
# Bearer token; set the same value here and in the Vercel project.
CRON_SECRET=

# ─── Stripe (invoicing) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email / alert sends (Resend) ─────────────────────────────────────────────
# Real sends fire ONLY when VERCEL_ENV=production AND this flag is "true" AND the
# key is present (see lib/email/guard.ts). Leave the flag unset/false anywhere a
# real client must not be emailed. Resend key + verified grantedco.com domain
# required before the TODO(resend) stub in lib/email/send.ts is replaced.
EMAIL_SENDING_ENABLED=false
RESEND_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
# Used to build auth redirect URLs. Set to your deployed origin in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

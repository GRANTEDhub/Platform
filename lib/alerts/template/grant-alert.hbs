<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{headline}}</title>
<!-- Brand fonts are embedded as local @font-face data URIs at render time
     (see lib/alerts/render.ts). No CDN <link>: serverless Chromium may have no
     egress to fonts.gstatic.com, and a competing/blocked CDN face is what
     garbled the glyphs. The embedded TTFs are the single source of truth. -->
<style>
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: #e8e2d8; }
  @page { size: letter; margin: 0; }
  @media print {
    html { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    html, body { background: #fff; }
    .brief-page { box-shadow: none !important; margin: 0 !important; }
  }
</style>
</head>
<body>
<div class="brief-page" style="width:816px; min-height:1056px; margin:24px auto; padding:18px 0; background:#fff; color:#0B1E3A; font-family:'Inter Tight', sans-serif; box-shadow:0 18px 50px rgba(11,30,58,0.18); display:flex; flex-direction:column;">

  <!-- ===================== TOP BAR ===================== -->
  <div style="display:flex; align-items:center; justify-content:space-between; padding:0 46px;">
    <!-- FIXED: GRANTED wordmark + tagline -->
    <div style="display:flex; align-items:center; gap:11px;">
      <img src="assets/granted-mark-navy.png" alt="GRANTED logo" width="31" height="31" style="display:block; flex-shrink:0;">
      <span style="font-family:'Source Serif 4', serif; font-weight:700; font-size:23px; letter-spacing:0.04em; color:#0B1E3A;">GRANTED</span>
      <span style="width:1px; height:15px; background:#b3541e; display:inline-block;"></span>
      <span style="font-family:'Source Serif 4', serif; font-style:italic; font-weight:700; font-size:14px; color:#b3541e;">More Grants. Less Grind.</span>
    </div>
    <!-- DYNAMIC: short alert label, e.g. "FEMA NSGP Alert" -->
    <span style="font-size:10.5px; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:#0B1E3A; opacity:0.55;">{{alertLabel}}</span>
  </div>

  <div style="height:1px; background:#0B1E3A; opacity:0.12; margin:14px 46px 0 46px;"></div>

  <!-- ===================== HERO ===================== -->
  <div style="padding:20px 46px 16px 46px;">
    <!-- DYNAMIC: eyebrow line. fon is CONDITIONAL. -->
    <div style="font-size:11px; font-weight:600; letter-spacing:0.15em; text-transform:uppercase; color:#b3541e; margin-bottom:10px;">
      {{programName}}{{#if programShort}} &middot; {{programShort}}{{/if}}{{#if fiscalYear}} &middot; {{fiscalYear}}{{/if}}{{#if fon}} &middot; FON {{fon}}{{/if}}
    </div>
    <!-- DYNAMIC: headline -->
    <h1 style="font-family:'Source Serif 4', serif; font-weight:700; font-size:38px; line-height:1.04; letter-spacing:-0.02em; margin:0 0 13px 0; color:#0B1E3A;">
      {{headline}}
    </h1>
    <!-- DYNAMIC: intro (rich html, may include the funder link) -->
    <!-- CONDITIONAL: state pass-through sentence appends only for state-administered grants -->
    <div style="font-size:14.5px; line-height:1.55; margin:0; max-width:700px; color:#2a3a52; text-wrap:pretty;">{{{introHtml}}}{{#if statePassThrough}} In {{state}} it runs through the {{administeringAgency}} as a pass-through, so your application competes only against other in-state organizations, not the entire country.{{/if}}</div>
  </div>

  <!-- ===================== STATS STRIP ===================== -->
  <!-- DYNAMIC: loop of 2–4 stats. Set highlight:true on the deadline (or any
       one) stat to render it in orange. Omit a stat (e.g. the match stat) by
       leaving it out of the array. -->
  <div style="display:grid; grid-template-columns:repeat({{stats.length}}, 1fr); background:rgba(11,30,58,0.85); margin:0 46px;">
    {{#each stats}}
    <div style="padding:11px 14px; {{#unless @last}}border-right:1px solid rgba(250,247,242,0.18); {{/unless}}display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; gap:4px;{{#if this.highlight}} background:rgba(179,84,30,0.85);{{/if}}">
      <span style="font-family:'Source Serif 4', serif; font-weight:700; font-size:20px; line-height:1; color:#fff;">{{this.value}}</span>
      <span style="font-size:9.5px; font-weight:600; letter-spacing:0.09em; text-transform:uppercase; color:{{#if this.highlight}}#fff{{else}}#f4d8c6{{/if}};">{{this.label}}</span>
    </div>
    {{/each}}
  </div>
  <!-- CONDITIONAL: footnote under the stats strip -->
  {{#if statsFootnote}}
  <div style="font-size:10px; line-height:1.4; margin:6px 46px 0 46px; color:#6b7688;">{{statsFootnote}}</div>
  {{/if}}

  <!-- ===================== WHAT IT FUNDS + WHO CAN APPLY ===================== -->
  <div style="display:grid; grid-template-columns:1.35fr 1fr; gap:34px; padding:14px 46px 2px 46px;">
    <div>
      <div style="font-size:10.5px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#b3541e; margin-bottom:11px;">What it funds</div>
      <!-- DYNAMIC: lead-in line -->
      <p style="font-size:13px; line-height:1.55; margin:0 0 8px 0; color:#2a3a52;">{{whatItFundsIntro}}</p>
      <!-- DYNAMIC: loop of chips -->
      <div style="display:flex; flex-wrap:wrap; gap:7px;">
        {{#each whatItFunds}}
        <span style="font-size:11.5px; font-weight:500; color:#0B1E3A; background:#faf7f2; border:1px solid rgba(11,30,58,0.12); border-radius:2px; padding:5px 9px;">{{this}}</span>
        {{/each}}
      </div>
    </div>
    <div>
      <div style="font-size:10.5px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#b3541e; margin-bottom:11px;">Who can apply</div>
      <!-- DYNAMIC: eligibility (rich html) -->
      <p style="font-size:13px; line-height:1.55; margin:0 0 10px 0; color:#2a3a52;">{{{eligibilityHtml}}}</p>
      <!-- CONDITIONAL: small labeled callout (e.g. reimbursement note) -->
      {{#if eligibilityNote}}
      <div style="display:flex; gap:10px; align-items:flex-start; background:#faf7f2; border-left:3px solid #b3541e; padding:10px 12px;">
        <div>
          <div style="font-size:10px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#b3541e; margin-bottom:3px;">{{eligibilityNote.label}}</div>
          <div style="font-size:12px; line-height:1.45; color:#2a3a52;">{{eligibilityNote.body}}</div>
        </div>
      </div>
      {{/if}}
    </div>
  </div>

  <!-- ===================== HOW GRANTED CAN HELP ===================== -->
  <div style="padding:14px 46px 4px 46px;">
    <div style="display:grid; grid-template-columns:1.05fr 1fr; gap:26px; align-items:start;">

      <!-- FIXED: How to get started (3 steps). See caveat in field-mapping.md. -->
      <div style="padding-top:12px;">
        <div style="font-size:10.5px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#b3541e; margin-bottom:10px;">How to get started</div>
        <div style="display:flex; flex-direction:column; gap:9px;">
          <div style="display:flex; gap:11px; align-items:flex-start;">
            <span style="font-family:'Source Serif 4', serif; font-weight:700; font-size:18px; color:#b3541e; line-height:1.1;">1</span>
            <div style="font-size:12px; line-height:1.42; color:#2a3a52;">Confirm your <b style="color:#0B1E3A;">SAM.gov registration (UEI)</b> is active. New or lapsed registrations can take 7&ndash;10 business days to clear.</div>
          </div>
          <div style="display:flex; gap:11px; align-items:flex-start;">
            <span style="font-family:'Source Serif 4', serif; font-weight:700; font-size:18px; color:#b3541e; line-height:1.1;">2</span>
            <div style="font-size:12px; line-height:1.42; color:#2a3a52;">Outline your <b style="color:#0B1E3A;">project scope and top priorities</b> for this funding.</div>
          </div>
          <div style="display:flex; gap:11px; align-items:flex-start;">
            <span style="font-family:'Source Serif 4', serif; font-weight:700; font-size:18px; color:#b3541e; line-height:1.1;">3</span>
            <div style="font-size:12px; line-height:1.42; color:#2a3a52;">Identify your <b style="color:#0B1E3A;">match or cost-share source</b>, if the program requires one.</div>
          </div>
        </div>
      </div>

      <!-- FIXED: "Then bring it to GRANTED" CTA. Inline DYNAMIC tokens: ctaSendItems, deadlineLong -->
      <div style="background:#0B1E3A; color:#faf7f2; padding:15px 18px; display:flex; flex-direction:column; justify-content:flex-start;">
        <div style="font-size:10.5px; font-weight:700; letter-spacing:0.13em; text-transform:uppercase; color:#e6b89a; margin-bottom:7px;">Then bring it to GRANTED</div>
        <p style="font-size:12px; line-height:1.5; margin:0 0 9px 0; color:#cdd6e2;">Send us {{ctaSendItems}} and we take it from there. We validate eligibility, shape the strongest strategy against the program&rsquo;s scoring criteria, and build a competitive application before the {{deadlineLong}} deadline.</p>
        <div style="font-size:11px; color:#faf7f2;"><b>support@grantedco.com</b> &nbsp;&middot;&nbsp; Not ready this cycle? We can position you for the next one.</div>
      </div>

    </div>
  </div>

  <!-- ===================== FOOTER (FIXED) ===================== -->
  <div style="margin-top:auto; background:#0B1E3A; color:#faf7f2; padding:13px 46px; display:grid; grid-template-columns:1.6fr 1fr; gap:30px; align-items:center;">
    <div>
      <div style="display:flex; align-items:center; gap:10px; margin-bottom:8px;">
        <img src="assets/granted-mark-white.png" alt="GRANTED logo" width="27" height="27" style="display:block; flex-shrink:0;">
        <span style="font-family:'Source Serif 4', serif; font-weight:700; font-size:18px; letter-spacing:0.03em;">GRANTED</span>
        <span style="font-family:'Source Serif 4', serif; font-style:italic; font-size:14px; color:#e6b89a;">More Grants. Less Grind.</span>
      </div>
      <p style="font-size:11.5px; line-height:1.5; margin:0; color:#cdd6e2;">GRANTED is a full-spectrum grant solutions firm and thought partner to mission-driven organizations across the US. From the first discovery conversation through final closeout, we find the grants, build the strategy, write the proposals, and manage the compliance. Your team stays focused on the work that matters most.</p>
    </div>
    <div style="text-align:right;">
      <div style="font-size:13px; font-weight:600; color:#faf7f2; margin-bottom:3px;">grantedco.com</div>
      <div style="font-size:13px; font-weight:500; color:#e6b89a; margin-bottom:10px;">support@grantedco.com</div>
      <div style="font-size:10px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#cdd6e2; opacity:0.7;">Bentonville, Arkansas</div>
    </div>
  </div>

</div>
</body>
</html>
